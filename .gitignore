# HyreAgent.ai — standard .gitignore for Python repos (resume-compiler, platform/services/scraping)

# Byte-compiled
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Environment & secrets
.env
.env.local
.env.*.local

# Testing
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
htmlcov/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Linting
.ruff_cache/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/

# Local data (do NOT commit production data)
temp/
tmp/
*.pickle
*.pkl
*.parquet
*.db
*.sqlite

# Build artifacts specific to LaTeX/Tectonic
*.aux
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc
*.out
